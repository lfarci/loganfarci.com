# Environment Variables for Local Development
#
# For local development, you can use absolute paths or paths relative to the src directory.
# The CI/CD workflow automatically sets these to absolute paths.
#
# To use this file:
# 1. Copy this file to .env.local
# 2. Update the paths below to match your local setup
# 3. Uncomment the variables you want to customize

# Articles Directory
# Path to the articles directory (absolute or relative to src directory)
# Examples:
#   - Absolute: /home/user/projects/loganfarci.com/content/articles
#   - Relative: ../content/articles
# Default if not set: ../content/articles
#ARTICLES_DIRECTORY=../content/articles

# Data Directory
# Path to the data directory (absolute or relative to src directory)
# Examples:
#   - Absolute: /home/user/projects/loganfarci.com/content/data
#   - Relative: ../content/data
# Default if not set: ../content/data
#DATA_DIRECTORY=../content/data

# Public Environment Variables
# GitHub Repository URL
#VITE_GITHUB_REPOSITORY_URL=https://github.com/lfarci/loganfarci.com

# Preview deployment details
#VITE_DEPLOYMENT_ENVIRONMENT=Preview
#VITE_COMMIT_HASH=dev

# Site URL (used for og:url and og:image in meta tags)
# Default if not set: https://loganfarci.com
#VITE_SITE_URL=https://loganfarci.com

# Azure Application Insights connection string
# Leave unset for local development to avoid sending telemetry from your machine.
# In production, this value is fetched from Azure Key Vault by the deploy workflow.
#VITE_APPINSIGHTS_CONNECTION_STRING=
